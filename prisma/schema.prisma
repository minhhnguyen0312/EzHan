generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum HskLevel {
  HSK1
  HSK2
  HSK3
  HSK4
  HSK5
  HSK6
}

enum SubmissionType {
  TEXT
  IMAGE
}

enum FeedbackStatus {
  PENDING
  COMPLETED
  FAILED
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model User {
  id                 String   @id @default(cuid())
  name               String?
  email              String   @unique
  emailVerified      DateTime?
  image              String?
  hskLevel           HskLevel @default(HSK1)
  vocabCount         Int      @default(10)
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  accounts    Account[]
  sessions    Session[]
  submissions WritingSubmission[]
  progress    UserProgress?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Daily Content ────────────────────────────────────────────────────────────

model DailyTopic {
  id              String   @id @default(cuid())
  date            String
  hskLevel        HskLevel
  titleZh         String
  titleEn         String
  promptZh        String   @db.Text
  promptEn        String   @db.Text
  suggestedLength String
  createdAt       DateTime @default(now())

  submissions WritingSubmission[]

  @@unique([date, hskLevel])
  @@map("daily_topics")
}

model DailyVocabularySet {
  id        String   @id @default(cuid())
  date      String
  hskLevel  HskLevel
  createdAt DateTime @default(now())

  words VocabularyWord[]

  @@unique([date, hskLevel])
  @@map("daily_vocabulary_sets")
}

model VocabularyWord {
  id           String   @id @default(cuid())
  setId        String
  hanzi        String
  pinyin       String
  definition   String
  partOfSpeech String
  sentences    Json
  position     Int
  createdAt    DateTime @default(now())

  set DailyVocabularySet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@map("vocabulary_words")
}

// ─── User Activity ────────────────────────────────────────────────────────────

model WritingSubmission {
  id             String         @id @default(cuid())
  userId         String
  topicId        String
  submissionType SubmissionType @default(TEXT)
  contentText    String?        @db.Text
  imageUrl       String?
  feedbackStatus FeedbackStatus @default(PENDING)
  feedback       Json?
  submittedAt    DateTime       @default(now())
  reviewedAt     DateTime?

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic DailyTopic @relation(fields: [topicId], references: [id])

  @@unique([userId, topicId])
  @@map("writing_submissions")
}

model UserProgress {
  id                String   @id @default(cuid())
  userId            String   @unique
  currentStreak     Int      @default(0)
  longestStreak     Int      @default(0)
  totalSubmissions  Int      @default(0)
  totalWordsStudied Int      @default(0)
  lastActivityDate  String?
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_progress")
}
